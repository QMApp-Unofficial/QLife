{
  "name": "qlife",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -c auto -n api,client \"tsx watch server/index.ts\" \"vite\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsup server/index.ts --format esm --target node20 --out-dir dist/server --clean",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "start": "node dist/server/index.js",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.1",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/manrope": "^5.2.8",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
